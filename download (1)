<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Certificate | EduChain AI+</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
    <!-- Navigation -->
    <nav class="bg-gradient-to-r from-purple-600 to-blue-600 text-white shadow-lg">
        <div class="container mx-auto px-6 py-4">
            <div class="flex items-center justify-between">
                <div class="text-2xl font-bold">🔗 EduChain AI+</div>
                <div class="space-x-4">
                    <a href="/" class="hover:text-gray-200">Home</a>
                    <a href="/admin" class="hover:text-gray-200">Admin</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container mx-auto px-6 py-12">
        {% if error %}
        <div class="max-w-2xl mx-auto bg-red-100 border border-red-400 text-red-700 px-6 py-8 rounded-lg text-center">
            <div class="text-6xl mb-4">❌</div>
            <h1 class="text-3xl font-bold mb-4">Certificate Not Found</h1>
            <p class="text-lg">{{ error }}</p>
            <a href="/" class="inline-block mt-6 bg-red-600 text-white px-6 py-3 rounded-lg hover:bg-red-700">
                Return Home
            </a>
        </div>
        {% else %}
        <div class="max-w-4xl mx-auto">
            <div class="bg-white rounded-lg shadow-2xl overflow-hidden">
                <!-- Header -->
                <div class="bg-gradient-to-r from-green-500 to-blue-500 text-white p-8 text-center">
                    <div class="text-6xl mb-4">✅</div>
                    <h1 class="text-4xl font-bold mb-2">Certificate Verified</h1>
                    <p class="text-lg opacity-90">Blockchain Authenticated Credential</p>
                </div>

                <!-- Certificate Details -->
                <div class="p-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                        <div>
                            <h3 class="text-sm font-semibold text-gray-600 mb-2">Certificate Type</h3>
                            <p class="text-xl font-bold text-gray-800">Certificate of {{ certificate.certificate.type }}</p>
                        </div>
                        <div>
                            <h3 class="text-sm font-semibold text-gray-600 mb-2">Certificate ID</h3>
                            <p class="text-xl font-mono text-gray-800">{{ certificate.certificate.certificate_id }}</p>
                        </div>
                    </div>

                    <div class="border-t border-gray-200 pt-6 mb-6">
                        <h2 class="text-2xl font-bold text-gray-800 mb-4">Student Information</h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <h3 class="text-sm font-semibold text-gray-600 mb-1">Name</h3>
                                <p class="text-lg text-gray-800">{{ certificate.certificate.student_name }}</p>
                            </div>
                            <div>
                                <h3 class="text-sm font-semibold text-gray-600 mb-1">Wallet Address</h3>
                                <p class="text-sm font-mono text-gray-800">{{ certificate.certificate.student_wallet }}</p>
                            </div>
                        </div>
                    </div>

                    <div class="border-t border-gray-200 pt-6 mb-6">
                        <h2 class="text-2xl font-bold text-gray-800 mb-4">Academic Details</h2>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div>
                                <h3 class="text-sm font-semibold text-gray-600 mb-1">Course</h3>
                                <p class="text-lg text-gray-800">{{ certificate.certificate.course }}</p>
                            </div>
                            <div>
                                <h3 class="text-sm font-semibold text-gray-600 mb-1">Grade</h3>
                                <p class="text-lg text-gray-800">{{ certificate.certificate.grade }}</p>
                            </div>
                            <div>
                                <h3 class="text-sm font-semibold text-gray-600 mb-1">Year</h3>
                                <p class="text-lg text-gray-800">{{ certificate.certificate.year }}</p>
                            </div>
                        </div>
                    </div>

                    {% if certificate.certificate.skills %}
                    <div class="border-t border-gray-200 pt-6 mb-6">
                        <h2 class="text-2xl font-bold text-gray-800 mb-4">AI-Extracted Skills</h2>
                        <div class="flex flex-wrap gap-2">
                            {% for skill in certificate.certificate.skills %}
                            <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm font-semibold">{{ skill }}</span>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}

                    <div class="border-t border-gray-200 pt-6 mb-6">
                        <h2 class="text-2xl font-bold text-gray-800 mb-4">Blockchain Verification</h2>
                        <div class="bg-gray-50 p-6 rounded-lg">
                            <div class="grid grid-cols-1 gap-4">
                                <div>
                                    <h3 class="text-sm font-semibold text-gray-600 mb-1">Block Hash</h3>
                                    <p class="text-sm font-mono text-gray-800 break-all">{{ certificate.block_hash }}</p>
                                </div>
                                <div>
                                    <h3 class="text-sm font-semibold text-gray-600 mb-1">Block Index</h3>
                                    <p class="text-lg text-gray-800">{{ certificate.block_index }}</p>
                                </div>
                                <div>
                                    <h3 class="text-sm font-semibold text-gray-600 mb-1">Timestamp</h3>
                                    <p class="text-lg text-gray-800">{{ certificate.timestamp }}</p>
                                </div>
                                <div>
                                    <h3 class="text-sm font-semibold text-gray-600 mb-1">Issuer Wallet</h3>
                                    <p class="text-sm font-mono text-gray-800">{{ certificate.certificate.admin_wallet }}</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="border-t border-gray-200 pt-6 mb-6">
                        <h2 class="text-2xl font-bold text-gray-800 mb-4">Trust Score</h2>
                        <div class="flex items-center">
                            <div class="w-full bg-gray-200 rounded-full h-8 mr-4">
                                <div class="bg-green-500 h-8 rounded-full flex items-center justify-center text-white font-bold" style="width: 100%">
                                    100%
                                </div>
                            </div>
                            <span class="text-2xl font-bold text-green-600">Verified ✓</span>
                        </div>
                        <p class="text-sm text-gray-600 mt-2">This certificate is authentic and has been verified on the EduChain AI+ blockchain.</p>
                    </div>

                    <!-- NFT Badge & QR Code -->
                    <div class="border-t border-gray-200 pt-6">
                        <h2 class="text-2xl font-bold text-gray-800 mb-4">Digital Assets</h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <h3 class="text-sm font-semibold text-gray-600 mb-2">NFT Badge</h3>
                                <img src="/static/nft_badges/{{ certificate.certificate.certificate_id }}_nft.png" alt="NFT Badge" class="w-full rounded-lg shadow-lg" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22400%22 height=%22300%22%3E%3Crect width=%22400%22 height=%22300%22 fill=%22%23e2e8f0%22/%3E%3Ctext x=%2250%25%22 y=%2250%25%22 text-anchor=%22middle%22 dy=%22.3em%22 fill=%22%23718096%22%3ENFT Badge%3C/text%3E%3C/svg%3E'">
                            </div>
                            <div>
                                <h3 class="text-sm font-semibold text-gray-600 mb-2">QR Code</h3>
                                <img src="/static/qr_codes/{{ certificate.certificate.certificate_id }}_qr.png" alt="QR Code" class="w-64 mx-auto rounded-lg shadow-lg" onerror="this.style.display='none'">
                                <p class="text-xs text-gray-600 mt-2 text-center">Scan to verify this certificate</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="bg-gray-100 p-6 text-center">
                    <p class="text-gray-700 mb-4">This certificate is permanently recorded on the blockchain and cannot be tampered with or forged.</p>
                    <a href="/" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 font-semibold">
                        Return Home
                    </a>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
</body>
</html>
